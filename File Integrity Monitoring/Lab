Add the following content:

#!/bin/bash

# File Integrity Monitoring Service
# Runs continuous monitoring and generates periodic reports

SERVICE_NAME="FIM_Monitor"
LOG_DIR="/home/$USER/monitoring_logs"
SERVICE_LOG="$LOG_DIR/fim_service.log"
PID_FILE="/home/$USER/fim_service.pid"

# Create necessary directories
mkdir -p "$LOG_DIR"

start_service() {
    if [ -f "$PID_FILE" ]; then
        echo "Service already running (PID: $(cat $PID_FILE))"
        return 1
    fi
    
    echo "Starting $SERVICE_NAME..."
    echo "Service started at $(date)" > "$SERVICE_LOG"
    
    # Start background monitoring
    (
        while true; do
            echo "$(date): Running integrity check..." >> "$SERVICE_LOG"
            ./file_integrity_checker.sh -s >> "$SERVICE_LOG" 2>&1
            ./critical_dirs_monitor.sh monitor >> "$SERVICE_LOG" 2>&1
            sleep 300  # Check every 5 minutes
        done
    ) &
    
    echo $! > "$PID_FILE"
    echo "$SERVICE_NAME started with PID $(cat $PID_FILE)"
    echo "Log file: $SERVICE_LOG"
}

stop_service() {
    if [ ! -f "$PID_FILE" ]; then
        echo "Service is not running"
        return 1
    fi
    
    PID=$(cat "$PID_FILE")
    echo "Stopping $SERVICE_NAME (PID: $PID)..."
    kill "$PID" 2>/dev/null
    rm -f "$PID_FILE"
    echo "Service stopped"
}

status_service() {
    if [ -f "$PID_FILE" ]; then
        PID=$(cat "$PID_FILE")
        if ps -p "$PID" > /dev/null 2>&1; then
            echo "$SERVICE_NAME is running (PID: $PID)"
            echo "Log file: $SERVICE_LOG"
            echo "Recent activity:"
            tail -5 "$SERVICE_LOG" 2>/dev/null
        else
            echo "$SERVICE_NAME is not running (stale PID file)"
            rm -f "$PID_FILE"
        fi
    else
        echo "$SERVICE_NAME is not running"
    fi
}

case "$1" in
    start)
        start_service
        ;;
    stop)
        stop_service
        ;;
    status)
        status_service
        ;;
    restart)
        stop_service
        sleep 2
        start_service
        ;;
    *)
        echo "Usage: $0 {start|stop|status|restart}"
        exit 1
        ;;
esac
