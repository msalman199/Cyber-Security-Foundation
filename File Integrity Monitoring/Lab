#!/bin/bash

# Critical Directory Monitoring Script
# Monitors system-critical directories for unauthorized changes

# Define critical directories to monitor
CRITICAL_DIRS=(
    "/etc"
    "/home/$USER/secure_files"
    "/var/log"
    "/usr/bin"
    "/usr/sbin"
)

LOG_DIR="/home/$USER/monitoring_logs"
MAIN_LOG="$LOG_DIR/critical_monitor.log"

# Create log directory
mkdir -p "$LOG_DIR"

# Function to setup audit rules for critical directories
setup_audit_rules() {
    echo "Setting up audit rules for critical directories..."
    
    for dir in "${CRITICAL_DIRS[@]}"; do
        if [ -d "$dir" ]; then
            echo "Adding audit rule for: $dir"
            sudo auditctl -w "$dir" -p rwxa -k "critical_dir_$(basename "$dir")"
        else
            echo "Warning: Directory $dir does not exist"
        fi
    done
    
    # Add specific file monitoring
    sudo auditctl -w /etc/passwd -p wa -k passwd_file
    sudo auditctl -w /etc/shadow -p wa -k shadow_file
    sudo auditctl -w /etc/sudoers -p wa -k sudoers_file
    
    echo "Audit rules configured successfully"
    sudo auditctl -l
}

# Function to create baseline for all critical directories
create_comprehensive_baseline() {
    echo "Creating comprehensive baseline for critical directories..."
    BASELINE_FILE="$LOG_DIR/critical_baseline_$(date +%Y%m%d).txt"
    
    echo "Critical Directory Baseline - $(date)" > "$BASELINE_FILE"
    echo "======================================" >> "$BASELINE_FILE"
    
    for dir in "${CRITICAL_DIRS[@]}"; do
        if [ -d "$dir" ]; then
            echo "" >> "$BASELINE_FILE"
            echo "Directory: $dir" >> "$BASELINE_FILE"
            echo "-------------------" >> "$BASELINE_FILE"
            find "$dir" -type f -exec md5sum {} \; 2>/dev/null >> "$BASELINE_FILE"
        fi
    done
    
    echo "Baseline created: $BASELINE_FILE"
}

# Function to monitor and generate alerts
monitor_critical_changes() {
    echo "Monitoring critical directories for changes..."
    echo "Critical Directory Monitor Started - $(date)" > "$MAIN_LOG"
    
    # Generate audit report for critical directories
    for dir in "${CRITICAL_DIRS[@]}"; do
        if [ -d "$dir" ]; then
            DIR_KEY="critical_dir_$(basename "$dir")"
            echo "" >> "$MAIN_LOG"
            echo "=== Changes in $dir ===" >> "$MAIN_LOG"
            sudo ausearch -k "$DIR_KEY" -ts today 2>/dev/null >> "$MAIN_LOG"
        fi
    done
    
    # Check for specific file changes
    echo "" >> "$MAIN_LOG"
    echo "=== Critical File Changes ===" >> "$MAIN_LOG"
    sudo ausearch -k passwd_file -ts today 2>/dev/null >> "$MAIN_LOG"
    sudo ausearch -k shadow_file -ts today 2>/dev/null >> "$MAIN_LOG"
    sudo ausearch -k sudoers_file -ts today 2>/dev/null >> "$MAIN_LOG"
    
    echo "Monitoring report generated: $MAIN_LOG"
    
    # Display summary
    echo ""
    echo "=== MONITORING SUMMARY ==="
    echo "Total audit rules active: $(sudo auditctl -l | wc -l)"
    echo "Log file location: $MAIN_LOG"
    echo "Baseline location: $LOG_DIR/"
}

# Function to generate security report
generate_security_report() {
    REPORT_FILE="$LOG_DIR/security_report_$(date +%Y%m%d_%H%M%S).txt"
    
    echo "Security Assessment Report - $(date)" > "$REPORT_FILE"
    echo "========================================" >> "$REPORT_FILE"
    echo "" >> "$REPORT_FILE"
    
    echo "1. AUDIT SYSTEM STATUS" >> "$REPORT_FILE"
    echo "----------------------" >> "$REPORT_FILE"
    sudo auditctl -s >> "$REPORT_FILE" 2>/dev/null
    echo "" >> "$REPORT_FILE"
    
    echo "2. ACTIVE MONITORING RULES" >> "$REPORT_FILE"
    echo "--------------------------" >> "$REPORT_FILE"
    sudo auditctl -l >> "$REPORT_FILE" 2>/dev/null
    echo "" >> "$REPORT_FILE"
    
    echo "3. RECENT SECURITY EVENTS" >> "$REPORT_FILE"
    echo "-------------------------" >> "$REPORT_FILE"
    sudo ausearch -ts today 2>/dev/null | tail -20 >> "$REPORT_FILE"
    echo "" >> "$REPORT_FILE"
    
    echo "4. FILE ACCESS SUMMARY" >> "$REPORT_FILE"
    echo "----------------------" >> "$REPORT_FILE"
    sudo aureport -f 2>/dev/null | tail -10 >> "$REPORT_FILE"
    echo "" >> "$REPORT_FILE"
    
    echo "Security report generated: $REPORT_FILE"
    cat "$REPORT_FILE"
}

# Main menu
case "$1" in
    setup)
        setup_audit_rules
        ;;
    baseline)
        create_comprehensive_baseline
        ;;
    monitor)
        monitor_critical_changes
        ;;
    report)
        generate_security_report
        ;;
    *)
        echo "Critical Directory Monitoring Tool"
        echo "Usage: $0 {setup|baseline|monitor|report}"
        echo ""
        echo "Commands:"
        echo "  setup     - Configure audit rules for critical directories"
        echo "  baseline  - Create integrity baseline for all critical directories"
        echo "  monitor   - Check for changes and generate monitoring report"
        echo "  report    - Generate comprehensive security report"
        exit 1
        ;;
esac
