Task 2: Creating Automated File Integrity Check Scripts
Subtask 2.1: Basic File Integrity Checker Using MD5
Step 1: Create a baseline integrity checker script

nano file_integrity_checker.sh
Add the following content:

#!/bin/bash

# File Integrity Monitoring Script
# This script creates checksums for files and compares them

MONITOR_DIR="/home/$USER/secure_files"
BASELINE_FILE="/home/$USER/file_baselines.txt"
REPORT_FILE="/home/$USER/integrity_report_$(date +%Y%m%d_%H%M%S).txt"

# Function to create baseline
create_baseline() {
    echo "Creating baseline for directory: $MONITOR_DIR"
    if [ -d "$MONITOR_DIR" ]; then
        find "$MONITOR_DIR" -type f -exec md5sum {} \; > "$BASELINE_FILE"
        echo "Baseline created: $BASELINE_FILE"
        echo "Files monitored: $(wc -l < "$BASELINE_FILE")"
    else
        echo "Error: Directory $MONITOR_DIR does not exist"
        exit 1
    fi
}

# Function to check integrity
check_integrity() {
    echo "Checking file integrity against baseline..."
    echo "Integrity Check Report - $(date)" > "$REPORT_FILE"
    echo "======================================" >> "$REPORT_FILE"
    
    if [ ! -f "$BASELINE_FILE" ]; then
        echo "Error: Baseline file not found. Run with -c to create baseline first."
        exit 1
    fi
    
    # Check current checksums against baseline
    CHANGES_FOUND=0
    
    while IFS= read -r line; do
        EXPECTED_HASH=$(echo "$line" | cut -d' ' -f1)
        FILE_PATH=$(echo "$line" | cut -d' ' -f3-)
        
        if [ -f "$FILE_PATH" ]; then
            CURRENT_HASH=$(md5sum "$FILE_PATH" | cut -d' ' -f1)
            if [ "$EXPECTED_HASH" != "$CURRENT_HASH" ]; then
                echo "CHANGED: $FILE_PATH" >> "$REPORT_FILE"
                echo "  Expected: $EXPECTED_HASH" >> "$REPORT_FILE"
                echo "  Current:  $CURRENT_HASH" >> "$REPORT_FILE"
                echo "  Time: $(date)" >> "$REPORT_FILE"
                echo "" >> "$REPORT_FILE"
                CHANGES_FOUND=1
            fi
        else
            echo "DELETED: $FILE_PATH" >> "$REPORT_FILE"
            echo "  Time: $(date)" >> "$REPORT_FILE"
            echo "" >> "$REPORT_FILE"
            CHANGES_FOUND=1
        fi
    done < "$BASELINE_FILE"
    
    # Check for new files
    find "$MONITOR_DIR" -type f | while read -r file; do
        if ! grep -q "$file" "$BASELINE_FILE"; then
            echo "NEW FILE: $file" >> "$REPORT_FILE"
            echo "  Hash: $(md5sum "$file" | cut -d' ' -f1)" >> "$REPORT_FILE"
            echo "  Time: $(date)" >> "$REPORT_FILE"
            echo "" >> "$REPORT_FILE"
            CHANGES_FOUND=1
        fi
    done
    
    if [ $CHANGES_FOUND -eq 0 ]; then
        echo "No changes detected" >> "$REPORT_FILE"
    fi
    
    echo "Integrity check complete. Report saved: $REPORT_FILE"
    cat "$REPORT_FILE"
}

# Main script logic
case "$1" in
    -c|--create)
        create_baseline
        ;;
    -s|--scan)
        check_integrity
        ;;
    *)
        echo "Usage: $0 {-c|--create|-s|--scan}"
        echo "  -c, --create    Create baseline checksums"
        echo "  -s, --scan      Scan for changes against baseline"
        exit 1
        ;;
esac
