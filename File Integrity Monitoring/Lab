#!/bin/bash

# Real-time File Integrity Monitor using inotify
MONITOR_DIR="/home/$USER/secure_files"
LOG_FILE="/home/$USER/realtime_monitor.log"

echo "Starting real-time monitoring of: $MONITOR_DIR"
echo "Log file: $LOG_FILE"
echo "Press Ctrl+C to stop monitoring"

# Create log file with header
echo "Real-time File Monitoring Log - Started $(date)" > "$LOG_FILE"
echo "=============================================" >> "$LOG_FILE"

# Monitor directory for changes
inotifywait -m -r -e modify,create,delete,move,attrib "$MONITOR_DIR" --format '%T %w%f %e' --timefmt '%Y-%m-%d %H:%M:%S' | while read -r event; do
    echo "$event" >> "$LOG_FILE"
    echo "ALERT: $event"
    
    # Send alert for critical events
    if echo "$event" | grep -q "DELETE\|MOVE"; then
        echo "CRITICAL: File deletion or move detected at $(date)" >> "$LOG_FILE"
    fi
done
Step 3: Make the script executable

chmod +x realtime_monitor.sh
Step 4: Test real-time monitoring (run in background)

