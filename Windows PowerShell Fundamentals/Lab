Subtask 3.4: Creating Complete Scripts
Script 1: File Management Automation
Create a comprehensive file management script:
# File Management Automation Script
Write-Host "=== File Management Automation ===" -ForegroundColor Green

# Create project directory structure
$projectName = "MyProject"
$directories = @("src", "docs", "tests", "config")

Write-Host "Creating project: $projectName"
New-Item -ItemType Directory -Name $projectName -Force

Set-Location $projectName

foreach ($dir in $directories) {
    New-Item -ItemType Directory -Name $dir -Force
    Write-Host "Created directory: $dir" -ForegroundColor Yellow
}

# Create sample files
$sampleFiles = @{
    "src/main.ps1" = "# Main PowerShell script"
    "docs/README.md" = "# Project Documentation"
    "tests/test.ps1" = "# Test script"
    "config/settings.json" = '{"version": "1.0"}'
}

foreach ($file in $sampleFiles.Keys) {
    New-Item -ItemType File -Path $file -Value $sampleFiles[$file] -Force
    Write-Host "Created file: $file" -ForegroundColor Cyan
}

Write-Host "Project structure created successfully!" -ForegroundColor Green
Script 2: System Information Gathering
Create a system information script:
# System Information Script
Write-Host "=== System Information Report ===" -ForegroundColor Magenta

# Get PowerShell version
Write-Host "`nPowerShell Version:" -ForegroundColor Yellow
$PSVersionTable.PSVersion

# Get current location
Write-Host "`nCurrent Location:" -ForegroundColor Yellow
Get-Location

# Count files and directories
$items = Get-ChildItem
$fileCount = ($items | Where-Object { -not $_.PSIsContainer }).Count
$dirCount = ($items | Where-Object { $_.PSIsContainer }).Count

Write-Host "`nDirectory Contents:" -ForegroundColor Yellow
Write-Host "Files: $fileCount"
Write-Host "Directories: $dirCount"

# Get largest files
Write-Host "`nLargest Files:" -ForegroundColor Yellow
Get-ChildItem -File | Sort-Object Length -Descending | Select-Object -First 5 | ForEach-Object {
    Write-Host "$($_.Name): $($_.Length) bytes"
}

Write-Host "`nReport completed!" -ForegroundColor Green
Script 3: Interactive File Organizer
Create an interactive file organization script:
# Interactive File Organizer
Write-Host "=== Interactive File Organizer ===" -ForegroundColor Blue

# Get file extensions in current directory
$extensions = Get-ChildItem -File | ForEach-Object { $_.Extension } | Sort-Object -Unique

if ($extensions.Count -eq 0) {
    Write-Host "No files found in current directory." -ForegroundColor Red
    exit
}

Write-Host "`nFound file extensions:" -ForegroundColor Yellow
for ($i = 0; $i -lt $extensions.Count; $i++) {
    Write-Host "$($i + 1). $($extensions[$i])"
}

# Create directories for each extension
foreach ($ext in $extensions) {
    if ($ext -ne "") {
        $folderName = $ext.TrimStart('.') + "_files"
        New-Item -ItemType Directory -Name $folderName -Force | Out-Null
        Write-Host "Created folder: $folderName" -ForegroundColor Green
    }
}

# Move files to appropriate directories
foreach ($ext in $extensions) {
    if ($ext -ne "") {
        $folderName = $ext.TrimStart('.') + "_files"
        $filesToMove = Get-ChildItem -File | Where-Object { $_.Extension -eq $ext }
        
        foreach ($file in $filesToMove) {
            Move-Item $file.FullName "$folderName/"
            Write-Host "Moved $($file.Name) to $folderName/" -ForegroundColor Cyan
        }
    }
}

Write-Host "`nFile organization completed!" -ForegroundColor Green
